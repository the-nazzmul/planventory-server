generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  WAREHOUSE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum StockMovementReason {
  SALE
  RESTOCK
  RETURN
  DAMAGE
  ADJUSTMENT
  INITIAL
}

enum ExpenseCategory {
  OPERATIONAL
  INVENTORY
  MARKETING
  PAYROLL
  UTILITIES
  OTHER
}

enum WebhookEvent {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  STOCK_LOW
  PRODUCT_UPDATED
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  name           String
  role           Role           @default(MANAGER)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  stockMovements StockMovement[]
  expenses       Expense[]
  orders         Order[]
  @@index([email])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
  @@index([family])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
  @@index([entity, entityId])
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  name        String
  slug        String          @unique
  description String?
  brandId     String
  brand       Brand           @relation(fields: [brandId], references: [id])
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  tags        String[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([brandId])
  @@index([categoryId])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([productId])
}

model ProductVariant {
  id             String               @id @default(cuid())
  productId      String
  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku            String               @unique
  size           String?
  color          String?
  colorHex       String?
  costPrice      Int
  sellingPrice   Int
  stock          Int                  @default(0)
  lowStockAlert  Int                  @default(10)
  barcode        String?              @unique
  weight         Float?
  dimensions     Json?
  stockMovements StockMovement[]
  orderItems     OrderItem[]
  purchaseItems  PurchaseOrderItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  @@index([productId])
  @@index([sku])
}

model StockMovement {
  id          String              @id @default(cuid())
  variantId   String
  variant     ProductVariant      @relation(fields: [variantId], references: [id])
  quantity    Int
  reason      StockMovementReason
  referenceId String?
  notes       String?
  performedBy String
  user        User                @relation(fields: [performedBy], references: [id])
  createdAt   DateTime            @default(now())
  @@index([variantId])
  @@index([createdAt])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  email          String?         @unique
  phone          String?
  address        Json?
  contactPerson  String?
  paymentTerms   String?
  isActive       Boolean         @default(true)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  status      String              @default("DRAFT")
  totalAmount Int
  notes       String?
  orderedAt   DateTime?
  receivedAt  DateTime?
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  quantity        Int
  unitCost        Int
  receivedQty     Int           @default(0)
  @@index([purchaseOrderId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress Json
  subtotal        Int
  taxAmount       Int         @default(0)
  discountAmount  Int         @default(0)
  shippingCost    Int         @default(0)
  totalAmount     Int
  notes           String?
  trackingNumber  String?
  idempotencyKey  String      @unique
  processedBy     String?
  processor       User?       @relation(fields: [processedBy], references: [id])
  items           OrderItem[]
  returns         Return[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  quantity   Int
  unitPrice  Int
  totalPrice Int
  @@index([orderId])
}

model Return {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  reason       String
  items        Json
  refundAmount Int
  restocked    Boolean  @default(false)
  processedBy  String
  createdAt    DateTime @default(now())
  @@index([orderId])
}

model Expense {
  id          String          @id @default(cuid())
  amount      Int
  category    ExpenseCategory
  description String
  reference   String?
  date        DateTime
  createdBy   String
  creator     User            @relation(fields: [createdBy], references: [id])
  createdAt   DateTime        @default(now())
  @@index([category])
  @@index([date])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Webhook {
  id        String         @id @default(cuid())
  url       String
  events    WebhookEvent[]
  secret    String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
